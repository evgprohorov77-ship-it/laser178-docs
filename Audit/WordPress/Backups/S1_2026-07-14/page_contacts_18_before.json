    "content": {
        "rendered": "<div style=\"padding: 40px 20px 80px; max-width: 1200px; margin: 0 auto;\">\n<div class=\"laser-card\" style=\"max-width: 700px; margin-bottom: 40px;\">\n<h2 style=\"font-size: 28px; margin-bottom: 20px;\">\u0410\u0434\u0440\u0435\u0441</h2>\n<p><strong>\u0421\u0430\u043d\u043a\u0442-\u041f\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433, \u0443\u043b. \u0413\u0440\u0443\u0437\u0438\u043d\u0441\u043a\u0430\u044f, 3 \u043a\u043e\u0440\u043f. 1\u041f</strong><br />\n        \u0412\u044a\u0435\u0437\u0434 \u0441\u043e \u0441\u0442\u043e\u0440\u043e\u043d\u044b \u0443\u043b. \u0421\u0430\u043b\u043e\u0432\u0430.</p>\n<h2 style=\"font-size: 28px; margin: 30px 0 20px;\">\u0420\u0435\u0436\u0438\u043c \u0440\u0430\u0431\u043e\u0442\u044b</h2>\n<p>\u041f\u043d\u2013\u041f\u0442: 10:00\u201319:00<br />\n        \u0421\u0431: 10:00\u201315:00<br />\n        \u0412\u0441: \u0432\u044b\u0445\u043e\u0434\u043d\u043e\u0439</p>\n<p>\u0417\u0430\u043f\u0438\u0441\u044c \u043f\u043e \u0442\u0435\u043b\u0435\u0444\u043e\u043d\u0443.</p>\n<h2 style=\"font-size: 28px; margin: 30px 0 20px;\">\u0422\u0435\u043b\u0435\u0444\u043e\u043d</h2>\n<p><a href=\"tel:+79810971505\" style=\"font-size: 24px; font-weight: bold;\">+7 (981) 097-15-05</a></p>\n<p>\u041f\u043e\u0437\u0432\u043e\u043d\u0438\u0442\u0435 \u0438\u043b\u0438 \u043d\u0430\u043f\u0438\u0448\u0438\u0442\u0435 \u2014 \u043c\u044b \u043e\u0442\u0432\u0435\u0442\u0438\u043c \u0432 \u0440\u0430\u0431\u043e\u0447\u0435\u0435 \u0432\u0440\u0435\u043c\u044f.</p>\n<h2 style=\"font-size: 28px; margin: 30px 0 20px;\">Email</h2>\n<p><a href=\"mailto:info@laser178.ru\">info@laser178.ru</a></p>\n<h2 style=\"font-size: 28px; margin: 30px 0 20px;\">\u0421\u0445\u0435\u043c\u0430 \u043f\u0440\u043e\u0435\u0437\u0434\u0430</h2>\n<p><a href=\"https://yandex.ru/maps/?ll=30.3209,59.8936&#038;z=16&#038;pt=30.3209,59.8936\" target=\"_blank\" rel=\"noopener\">\u041e\u0442\u043a\u0440\u044b\u0442\u044c \u043a\u0430\u0440\u0442\u0443 \u042f\u043d\u0434\u0435\u043a\u0441\u0430 \u2014 \u0443\u043b. \u0413\u0440\u0443\u0437\u0438\u043d\u0441\u043a\u0430\u044f, 3 \u043a\u043e\u0440\u043f. 1\u041f</a></p>\n<h2 style=\"font-size: 28px; margin: 30px 0 20px;\">\u041a\u0430\u043a \u0437\u0430\u043f\u0438\u0441\u0430\u0442\u044c\u0441\u044f</h2>\n<ol>\n<li>\u041f\u043e\u0437\u0432\u043e\u043d\u0438\u0442\u0435 \u043f\u043e \u0442\u0435\u043b\u0435\u0444\u043e\u043d\u0443 <a href=\"tel:+79810971505\">+7 (981) 097-15-05</a>.</li>\n<li>\u0417\u0430\u043f\u0438\u0448\u0438\u0442\u0435\u0441\u044c \u043d\u0430 \u0443\u0434\u043e\u0431\u043d\u043e\u0435 \u0432\u0440\u0435\u043c\u044f.</li>\n<li>\u041f\u0440\u0438\u0435\u0437\u0436\u0430\u0439\u0442\u0435 \u043f\u043e \u0430\u0434\u0440\u0435\u0441\u0443: \u0443\u043b. \u0413\u0440\u0443\u0437\u0438\u043d\u0441\u043a\u0430\u044f, 3 \u043a\u043e\u0440\u043f. 1\u041f.</li>\n</ol></div>\n</div>\n<p><script type=\"application/ld+json\">\n{\n  \"@context\": \"https://schema.org\",\n  \"@type\": \"LocalBusiness\",\n  \"name\": \"\u041b\u0430\u0437\u0435\u0440 \u0410\u043d\u0442\u0438\u043a\u043e\u0440\",\n  \"image\": \"https://laser178.ru/wp-content/uploads/logo.png\",\n  \"telephone\": \"+79810971505\",\n  \"email\": \"info@laser178.ru\",\n  \"address\": {\n    \"@type\": \"PostalAddress\",\n    \"streetAddress\": \"\u0443\u043b. \u0413\u0440\u0443\u0437\u0438\u043d\u0441\u043a\u0430\u044f, 3 \u043a\u043e\u0440\u043f. 1\u041f\",\n    \"addressLocality\": \"\u0421\u0430\u043d\u043a\u0442-\u041f\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\",\n    \"addressRegion\": \"\u0421\u041f\u0431\",\n    \"addressCountry\": \"RU\"\n  },\n  \"openingHours\": [\"Mo-Fr 10:00-19:00\", \"Sa 10:00-15:00\"],\n  \"url\": \"https://laser178.ru\",\n  \"areaServed\": \"\u0421\u0430\u043d\u043a\u0442-\u041f\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\"\n}\n</script></p>\n",
